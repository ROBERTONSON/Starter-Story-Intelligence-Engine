# Environment Variables Configuration
# Copy this file to .env and fill in the corresponding values.

# 1. LLM API Key (Fill at least the one you plan to use)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Set this variable to "openai", "anthropic", or "gemini" depending on your choice
LLM_PROVIDER=openai

# 2. Database Connection (E.g., Supabase)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# Firebase alternative (if using Firebase instead)
# FIREBASE_CREDENTIALS_PATH=./config/firebase_service_account.json
DB_TARGET=supabase # Options: supabase, firebase, postgresql

# 3. Web Scraper/YouTube specific configs (if any like rapid api key)
YOUTUBE_API_KEY=your_youtube_api_key_here # Optional if using headless scraper
